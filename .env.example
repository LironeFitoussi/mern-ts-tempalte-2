# ============================================
# Docker Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ============================================
# MongoDB Configuration
# ============================================
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=your_secure_password_here
MONGO_DATABASE=mern_db
MONGO_PORT=27017
MONGO_URI=mongodb://admin:your_secure_password_here@mongodb:27017/mern_db?authSource=admin

# ============================================
# Server Configuration
# ============================================
SERVER_PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ============================================
# Client Configuration
# ============================================
CLIENT_PORT=5173
VITE_API_URL=
VITE_PROXY_TARGET=http://server:3000

# ============================================
# Auth0 Configuration (Server) - REQUIRED
# ============================================
# Get these from your Auth0 Dashboard:
# 1. Applications > Your App > Settings (Domain, Client ID)
# 2. APIs > Your API > Settings (Identifier = AUDIENCE)
# 3. Create Machine to Machine app for Client Secret
AUTH0_DOMAIN=your-auth0-domain.auth0.com
AUTH0_AUDIENCE=https://your-api-identifier
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret

# ============================================
# Auth0 Configuration (Client) - REQUIRED
# ============================================
VITE_AUTH0_DOMAIN=your-auth0-domain.auth0.com
VITE_AUTH0_CLIENT_ID=your-client-id
VITE_AUTH0_AUDIENCE=https://your-api-identifier
