# ============================================
# Server Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# ============================================
# Server Configuration
# ============================================
# Port number for the Express server
PORT=3000

# Environment mode: development | production
NODE_ENV=development

# ============================================
# Database Configuration
# ============================================
# MongoDB connection string
# Local MongoDB: mongodb://localhost:27017/your-app-name
# MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/database-name
MONGO_URI=mongodb://localhost:27017/your-app-name

# ============================================
# CORS Configuration
# ============================================
# Frontend URL for CORS (allowed origins)
# Development: http://localhost:5173
# Production: https://your-production-domain.com
CLIENT_URL=http://localhost:5173

# ============================================
# Auth0 Configuration
# ============================================
# Your Auth0 tenant domain (without https://)
# Example: dev-abc123.us.auth0.com
AUTH0_DOMAIN=your-auth0-domain.auth0.com

# Auth0 API Audience (API Identifier)
# This must match the identifier you set when creating your Auth0 API
# Example: https://your-api-identifier
AUTH0_AUDIENCE=https://your-api-identifier
