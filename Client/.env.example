# ============================================
# Client Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control
# Note: Vite requires the VITE_ prefix for all environment variables

# ============================================
# API Configuration
# ============================================
# Backend API base URL
# Development: http://localhost:3000/api
# Production: https://your-backend-api.com/api
VITE_API_URL=http://localhost:3000/api

# ============================================
# Auth0 Configuration
# ============================================
# Your Auth0 tenant domain (without https://)
# Example: dev-abc123.us.auth0.com
# This should match the AUTH0_DOMAIN in your Server .env file
VITE_AUTH0_DOMAIN=your-auth0-domain.auth0.com

# Auth0 Application Client ID
# Found in your Auth0 Application settings
# Example: abc123xyz456def789
VITE_AUTH0_CLIENT_ID=your-auth0-client-id

# Auth0 API Audience (API Identifier)
# This must match the identifier you set when creating your Auth0 API
# Example: https://your-api-identifier
# This should match the AUTH0_AUDIENCE in your Server .env file
VITE_AUTH0_AUDIENCE=https://your-api-identifier
